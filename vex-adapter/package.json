{
  "name": "@vektormemory/vex-adapter",
  "version": "0.1.0",
  "description": "vec2vec linear projection adapter for vex — translate embeddings between models without re-embedding.",
  "type": "module",
  "bin": {
    "vex-adapt": "./bin/vex-adapt.mjs"
  },
  "main": "./adapter/index.js",
  "exports": {
    ".": "./adapter/index.js",
    "./train": "./adapter/train.js",
    "./models": "./adapter/models.js"
  },
  "files": [
    "bin/",
    "adapter/",
    "scripts/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": ["vector", "embeddings", "adapter", "projection", "vex", "vektor", "migration"],
  "license": "Apache-2.0",
  "peerDependencies": {
    "@vektormemory/vex": ">=0.2.0"
  },
  "dependencies": {},
  "engines": { "node": ">=18" },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vektor-Memory/vex-adapter"
  }
}
